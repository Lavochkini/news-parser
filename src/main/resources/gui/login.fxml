<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" style="-fx-background-color: #1e1e1e; -fx-padding: 20;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lake_team.fistserios.gui.controller.LoginController">

    <Label

                    style="-fx-font-size: 55; -fx-text-fill: blue; -fx-font-weight: bold;" text="MrDaks" />



    <Label
                    style="-fx-font-size: 24; -fx-text-fill: white; -fx-font-weight: bold;" text="Login" />


    <TextField fx:id="usernameField" promptText="User Name" prefWidth="400" maxWidth="400" VBox.vgrow="NEVER"
                    style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;">
    <VBox.margin>
        <Insets top="0" right="0" bottom="20" left="0"/>
    </VBox.margin>
    </TextField>



    <PasswordField fx:id="passwordField" promptText="Password" prefWidth="400" maxWidth="400" VBox.vgrow="NEVER"
                   style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;">
    <VBox.margin>
        <Insets top="0" right="0" bottom="20" left="0"/>
    </VBox.margin>
    </PasswordField>


    <Button onAction="#handleLogin"
                    style="-fx-background-color: #3a3a3a; -fx-text-fill: white; -fx-font-weight: bold;" text="Login" />


    <HBox alignment="CENTER" spacing="40">
        <Label onMouseClicked="#openRegistration" text="Registration" textFill="skyblue" translateX="-20" />
        <Label onMouseClicked="#openGuest" text="Guest" textFill="lightgreen" />
      <opaqueInsets>
         <Insets />
      </opaqueInsets>
    </HBox>

</VBox>
