<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>


<?import javafx.scene.text.Text?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lake_team.fistserios.gui.controller.RegistrationController"

      alignment="CENTER" spacing="15" style="-fx-background-color: #1e1e1e; -fx-padding:20 ">

    <Label

            style="-fx-font-size: 55; -fx-text-fill: blue; -fx-font-weight: bold;" text="MrDaks" />

    <Label
        style="-fx-font-size:25; -fx-text-fill: white; -fx-font-weight: bold" text="Registration"/>

    <TextField fx:id="usernameField" promptText="User Name" prefWidth="400" maxWidth="400" VBox.vgrow="NEVER"
           style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;">
    <VBox.margin>
        <Insets top="0" right="0" bottom="20" left="0"/>
    </VBox.margin>
    </TextField>

    <PasswordField fx:id="passwortField" promptText="Passwort" prefWidth="400" maxWidth="400" VBox.vgrow="NEVER"
               style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;">
    <VBox.margin>
        <Insets top="0" right="0" bottom="20" left="0"/>
    </VBox.margin>
    </PasswordField>

    <TextField fx:id="emailField" promptText="E-Mail" prefWidth="400" maxWidth="400" VBox.vgrow="NEVER"
               style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;">
    <VBox.margin>
        <Insets top="0" right="0" bottom="20" left="0"/>
    </VBox.margin>
    </TextField>

    <Button onAction="#handleRegister"
            style="-fx-background-color: #3a3a3a; -fx-text-fill: white; -fx-font-weight: bold;" text="Create" />

    <HBox alignment="CENTER" spacing="40">
        <Label onMouseClicked="#openLogin" text="Login" textFill="skyblue"  />
        <Label onMouseClicked="#openGuest" text="Guest" textFill="lightgreen" />
    </HBox>
</VBox>
