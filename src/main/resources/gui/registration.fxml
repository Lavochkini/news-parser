<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>



<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lake_team.fistserios.gui.controller.RegistrationController"
      alignment="CENTER" spacing="15" style="-fx-background-color: #1e1e1e; -fx-padding:20 ">

    <ImageView fx:id="imageView" fitWidth="300" preserveRatio="true" />
    <VBox spacing="15" alignment="CENTER">

    <Label style="-fx-font-size: 55; -fx-text-fill: blue; -fx-font-weight: bold;" text="MrDaks" />

    <Label style="-fx-font-size:25; -fx-text-fill: white; -fx-font-weight: bold" text="Registration"/>

    <!-- Username -->
    <VBox alignment="CENTER">
        <TextField fx:id="usernameField" promptText="User Name" prefWidth="400" maxWidth="400"
                   style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;"/>
        <Label fx:id="userNameErrorLabel" text="" textFill="red" style="-fx-font-size: 12;"/>
    </VBox>

    <!-- Password -->
    <VBox alignment="CENTER">
        <PasswordField fx:id="passwordField" promptText="Password" prefWidth="400" maxWidth="400"
                       style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;"/>
        <Label fx:id="passwordErrorLabel" text="" textFill="red" style="-fx-font-size: 12;"/>
    </VBox>

    <!-- Email -->
    <VBox alignment="CENTER">
        <TextField fx:id="emailField" promptText="E-Mail" prefWidth="400" maxWidth="400"
                   style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;"/>
        <Label fx:id="emailErrorLabel" text="" textFill="red" style="-fx-font-size: 12;"/>
    </VBox>

    <Button onAction="#handleRegister"
            style="-fx-background-color: #3a3a3a; -fx-text-fill: white; -fx-font-weight: bold;"
            text="Create" />

    <HBox alignment="CENTER" spacing="40">
        <Label onMouseClicked="#openLogin" text="Login" textFill="skyblue"  />
        <Label onMouseClicked="#openGuest" text="Guest" textFill="lightgreen" />
    </HBox>
    </VBox>
    <ImageView fx:id="imageViewRight" fitWidth="300" preserveRatio="true" />
</HBox>

