<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.SplitPane?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.lake_team.fistserios.gui.controller.MainController"
            style="-fx-background-color: #1e1e1e;">

    <center>
        <SplitPane dividerPositions="0.2">

            <items>
                <VBox style="-fx-background-color: #303A4C;">
                    <TextField fx:id="topicsearchField" promptText="Search" VBox.vgrow="SOMETIMES"
                               style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;">
                        <VBox.margin>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </VBox.margin>
                    </TextField>
                </VBox>


                <VBox style="-fx-background-color: #1B2029;">

                    <TextField fx:id="mainsearchField" promptText="Search" VBox.vgrow="SOMETIMES"
                               style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;">
                        <VBox.margin>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </VBox.margin>
                    </TextField>

                    <HBox alignment="CENTER" spacing="40">
                        <Label onMouseClicked="#openLogin" text="Login" textFill="skyblue"  />
                        <Label onMouseClicked="#openRegistration" text="Registration" textFill="skyblue" />
                    </HBox>
                </VBox>
            </items>
        </SplitPane>
    </center>
</BorderPane>