<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lake_team.fistserios.gui.controller.LoginController"
      spacing="15"
      alignment="CENTER"
      style="-fx-background-color: #1e1e1e; -fx-padding: 40;">

    <ImageView fx:id="imageView" fitWidth="300" preserveRatio="true" />

    <VBox spacing="15" alignment="CENTER">

        <Label style="-fx-font-size: 55; -fx-text-fill: blue; -fx-font-weight: bold;" text="Fistserios" />

        <Label style="-fx-font-size: 24; -fx-text-fill: white; -fx-font-weight: bold;" text="Login" />

        <TextField fx:id="emailField" promptText="E-mail" prefWidth="400" maxWidth="400"
                   style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;" />

        <Label fx:id="emailErrorLabel" text="" style="-fx-font-size: 12; -fx-text-fill: red; -fx-font-weight: bold;" />

        <PasswordField fx:id="passwordField" promptText="Password" prefWidth="400" maxWidth="400"
                       style="-fx-background-color: #2d2d2d; -fx-text-fill: white; -fx-prompt-text-fill: gray;" />

        <Label fx:id="passwordErrorLabel" text="" style="-fx-font-size: 12; -fx-text-fill: red; -fx-font-weight: bold;" />

        <Button onAction="#handleLogin"
                style="-fx-background-color: #3a3a3a; -fx-text-fill: white; -fx-font-weight: bold;" text="Login" />

        <HBox alignment="CENTER" spacing="40">
            <Label onMouseClicked="#openRegistration" text="Registration" textFill="skyblue" />
            <Label onMouseClicked="#openGuest" text="Guest" textFill="lightgreen" />
        </HBox>
    </VBox>

    <!-- Справа: зображення -->
    <ImageView fx:id="imageViewRight" fitWidth="300" preserveRatio="true" />


</HBox>
